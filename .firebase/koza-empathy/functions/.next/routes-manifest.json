      "routeKeys": {},
      "namedRegex": "^/api/auth/logout(?:/)?$"
    },
    {
      "page": "/api/auth/me",
      "regex": "^/api/auth/me(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/me(?:/)?$"
    },
    {
      "page": "/api/community/media",
      "regex": "^/api/community/media(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/community/media(?:/)?$"
    },
    {
      "page": "/api/community/notifications",
      "regex": "^/api/community/notifications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/community/notifications(?:/)?$"
    },
    {
